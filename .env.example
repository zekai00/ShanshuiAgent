# Copy this file to .env and fill only the values needed by your local run.

# Project/runtime paths
CL_PROJECT_ROOT=.
CL_DATA_DIR=./data
CL_DATASETS_ROOT=./datasets
CL_AUTHORITY_CORPUS_DIR=./datasets/chinese_landscape_authority_corpus
CL_MODELS_DIR=./models
CL_MODEL_DEVICE=cuda:0
CL_LLAMA_FACTORY_DIR=../LLaMA-Factory

# LLM endpoint
CL_LLM_API_KEY=
CL_LLM_BASE_URL=http://localhost:8000/v1
CL_FAST_LLM_MODEL=local-chat-model

# Retrieval service
CL_RETRIEVAL_HOST=127.0.0.1
CL_RETRIEVAL_PORT=8000
CL_RETRIEVAL_SERVICE_URL=http://127.0.0.1:8000

# Local model paths
CL_BGE_M3_PATH=./models/bge-m3
CL_RERANKER_PATH=./models/bge-reranker-v2-m3
CL_VLM_CRITIC_MODEL_PATH=./models/Qwen3-VL-4B-Instruct
CL_VLM_CRITIC_ENABLED=1
CL_VLM_CRITIC_PASS_SCORE=0.65
CL_VLM_CRITIC_MAX_NEW_TOKENS=700
CL_AUTHORITY_MILVUS_DB_PATH=./data/vector_store/milvus_authority.db
CL_AUTHORITY_COLBERT_TENSORS_PATH=./data/vector_store/colbert_authority_tensors.pkl
CL_RETRIEVAL_MILVUS_DB_PATH=./data/vector_store/milvus_authority.db
CL_RETRIEVAL_COLBERT_TENSORS_PATH=./data/vector_store/colbert_authority_tensors.pkl
CL_RETRIEVAL_EVIDENCE_DIR=./data/processed/authority_evidence

# Neo4j graph retrieval
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ComfyUI image generation
CL_COMFYUI_SERVER_URL=http://127.0.0.1:8188
CL_COMFYUI_WORKFLOW_PATH=./workflows/flux1_krea_dev-api.json
