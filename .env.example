# Copy this file to .env and fill only the values needed by your local run.

# Project/runtime paths
CL_PROJECT_ROOT=/root/Workspace/ChineseLandscape
CL_DATA_DIR=/root/Workspace/ChineseLandscape/data
CL_DATASETS_ROOT=/root/datasets
CL_AUTHORITY_CORPUS_DIR=/root/datasets/chinese_landscape_authority_corpus
CL_MODELS_DIR=/root/models
CL_MODEL_DEVICE=cuda:0
CL_LLAMA_FACTORY_DIR=/root/Workspace/LLaMA-Factory

# LLM provider
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Retrieval service
CL_RETRIEVAL_HOST=127.0.0.1
CL_RETRIEVAL_PORT=8000
CL_RETRIEVAL_SERVICE_URL=http://127.0.0.1:8000

# Local model paths
CL_BGE_M3_PATH=/root/models/bge-m3
CL_RERANKER_PATH=/root/models/bge-reranker-v2-m3
CL_AUTHORITY_MILVUS_DB_PATH=/root/Workspace/ChineseLandscape/data/vector_store/milvus_authority.db
CL_AUTHORITY_COLBERT_TENSORS_PATH=/root/Workspace/ChineseLandscape/data/vector_store/colbert_authority_tensors.pkl
CL_RETRIEVAL_MILVUS_DB_PATH=/root/Workspace/ChineseLandscape/data/vector_store/milvus_authority.db
CL_RETRIEVAL_COLBERT_TENSORS_PATH=/root/Workspace/ChineseLandscape/data/vector_store/colbert_authority_tensors.pkl
CL_RETRIEVAL_EVIDENCE_DIR=/root/Workspace/ChineseLandscape/data/processed/authority_evidence

# Neo4j graph retrieval
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ComfyUI image generation
CL_COMFYUI_SERVER_URL=http://127.0.0.1:8188
CL_COMFYUI_WORKFLOW_PATH=/root/Workspace/ChineseLandscape/workflows/flux1_krea_dev-api.json
